{
  "redirects": [
    { "source": "/cartographer", "destination": "https://cartographer.molar.it", "permanent": true },
    { "source": "/clones", "destination": "https://clones.molar.it", "permanent": true },
    { "source": "/guard", "destination": "https://guard.molar.it", "permanent": true },
    { "source": "/trace", "destination": "https://trace.molar.it", "permanent": true }
  ],
  "rewrites": [
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/thesis", "destination": "/thesis.html" },
    { "source": "/qa-agent", "destination": "/qa-agent.html" },
    { "source": "/vs/cypress", "destination": "/vs/cypress.html" },
    { "source": "/vs/playwright", "destination": "/vs/playwright.html" },
    { "source": "/integrations/github-actions", "destination": "/integrations/github-actions.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/test-stripe-without-real-cards", "destination": "/blog/test-stripe-without-real-cards.html" },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "cartographer.molar.it" }],
      "destination": "/cartographer/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "clones.molar.it" }],
      "destination": "/clones/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "guard.molar.it" }],
      "destination": "/guard/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "trace.molar.it" }],
      "destination": "/trace/index.html"
    }
  ]
}
